  "mcp": {
    "perplexity-ask": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "-e", "PERPLEXITY_API_KEY", "mcp/perplexity-ask"],
      "enabled": true
    },
    "fuzu-metabase": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "-e", "DATABASE_URL", "mcp/postgres"],
      "enabled": true
    },
    "fuzu-production": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "-e", "DATABASE_URL", "mcp/postgres"],
      "enabled": true
    },
    "fuzu-staging": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "-e", "DATABASE_URL", "mcp/postgres"],
      "enabled": true
    },
    "barona-production": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "-e", "DATABASE_URL", "mcp/postgres"],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["/Users/janni/.local/bin/uv", "--directory", "/Users/janni/git/mcp-memory-service", "run", "memory"],
      "enabled": true,
      "environment": {
        "MCP_MEMORY_CHROMA_PATH": "/Users/janni/.claude_chroma_db",
        "MCP_MEMORY_BACKUPS_PATH": "/Users/janni/.claude_chroma_backups"
      }
    }
  }
}