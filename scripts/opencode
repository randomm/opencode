#!/usr/bin/env bash
# OpenCode Unified Container Launcher
# Smart helper that attaches to existing container or creates new one
# Supports persistent screen sessions accessible from Mac and iPhone
#
# Usage:
#   ./scripts/opencode                    # Attach to existing or start new
#   ./scripts/opencode --new-session      # Create new screen window
#   ./scripts/opencode --ssh              # Show SSH connection info
#   ./scripts/opencode --status           # Check container status
#   ./scripts/opencode --stop             # Stop container
#   ./scripts/opencode --help             # Show help

set -euo pipefail

# =============================================================================
# Configuration
# =============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="$(dirname "$SCRIPT_DIR")"
COMPOSE_FILE="$CONFIG_DIR/docker-compose.yml"
CONTAINER_NAME="opencode"
SESSION_NAME="opencode-main"
REMORY_COMPOSE_FILE="${REMORY_COMPOSE_FILE:-$HOME/git/remory/docker-compose.mcp.yml}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# =============================================================================
# Helper Functions
# =============================================================================

log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

show_help() {
    cat << EOF
OpenCode Unified Container - Smart Launcher

Usage:
  $(basename "$0") [OPTIONS]

Options:
  (no options)      Attach to existing container or start new
  --new-session     Create new screen window in existing session
  --ssh             Show SSH connection information
  --status          Show container status
  --stop            Stop the container
  --help            Show this help message

Examples:
  # Start or attach to OpenCode
  ./scripts/opencode

  # Detach from session: Ctrl+A then D

  # Reattach later (from Mac or iPhone)
  ./scripts/opencode

  # Create new window in session
  ./scripts/opencode --new-session

  # Get SSH info for iPhone
  ./scripts/opencode --ssh

Session Management:
  Screen Commands (inside container):
    Ctrl+A D         - Detach (session keeps running)
    Ctrl+A C         - Create new window
    Ctrl+A N         - Next window
    Ctrl+A P         - Previous window
    Ctrl+A "         - List windows
    Ctrl+A [         - Scrollback mode

Multi-Device Workflow:
  1. Mac:    ./scripts/opencode
  2. Work in session
  3. Detach: Ctrl+A D
  4. iPhone: ssh opencode@<tailscale-ip>
  5. iPhone: screen -r opencode-main
  6. Continue working in same session!

EOF
}

check_docker() {
    if ! command -v docker &> /dev/null; then
        log_error "Docker is not installed"
        exit 1
    fi

    if ! docker info &> /dev/null; then
        log_error "Docker daemon is not running"
        exit 1
    fi
}

check_env() {
    # Check for required environment variables
    if [[ -z "${PERPLEXITY_API_KEY:-}" ]]; then
        log_warn "PERPLEXITY_API_KEY not set - Perplexity MCP server will not work"
    fi
    
    if [[ -z "${TS_AUTHKEY:-}" ]]; then
        log_warn "TS_AUTHKEY not set - Tailscale will require manual authentication"
    fi
}

check_remory() {
    log_info "Checking Remory MCP server..."

    if docker ps --filter "name=remory_mcp_server" --format "{{.Names}}" | grep -q remory_mcp_server; then
        log_success "Remory MCP server is running"
        return 0
    fi

    log_warn "Remory MCP server is not running"

    if [[ -f "$REMORY_COMPOSE_FILE" ]]; then
        log_info "Starting Remory services..."
        docker compose -f "$REMORY_COMPOSE_FILE" up -d

        sleep 5

        if docker ps --filter "name=remory_mcp_server" --format "{{.Names}}" | grep -q remory_mcp_server; then
            log_success "Remory services started"
        else
            log_error "Failed to start Remory services"
            exit 1
        fi
    else
        log_warn "Remory compose file not found: $REMORY_COMPOSE_FILE"
        log_info "Continuing without Remory (some MCP features may not work)"
    fi
}

is_container_running() {
    docker ps --filter "name=^${CONTAINER_NAME}$" --format "{{.Names}}" | grep -q "^${CONTAINER_NAME}$"
}

get_container_status() {
    if is_container_running; then
        echo "running"
    elif docker ps -a --filter "name=^${CONTAINER_NAME}$" --format "{{.Names}}" | grep -q "^${CONTAINER_NAME}$"; then
        echo "stopped"
    else
        echo "not_created"
    fi
}

start_container() {
    log_info "Starting OpenCode container..."
    
    cd "$CONFIG_DIR"
    docker compose -f "$COMPOSE_FILE" up -d
    
    # Wait for container to be ready
    log_info "Waiting for services to initialize..."
    sleep 5
    
    # Check if screen session is running
    if docker exec "$CONTAINER_NAME" su - opencode -c "screen -ls" | grep -q "$SESSION_NAME"; then
        log_success "Container started with screen session '$SESSION_NAME'"
    else
        log_warn "Container started but screen session may not be ready"
    fi
}

attach_to_session() {
    log_info "Attaching to screen session '$SESSION_NAME'..."
    echo ""
    log_info "===================================================================="
    log_info "  OpenCode Unified Container"
    log_info "===================================================================="
    log_info ""
    log_info "  Workspace:      /workspace (~/git)"
    log_info "  Session:        $SESSION_NAME (persistent)"
    log_info "  MCP Servers:    Remory + Perplexity"
    log_info "  Docker Socket:  Accessible"
    log_info ""
    log_info "  Detach:         Ctrl+A then D"
    log_info "  New Window:     Ctrl+A then C"
    log_info "  List Windows:   Ctrl+A then \""
    log_info "===================================================================="
    echo ""
    
    # Attach to screen session
    docker exec -it "$CONTAINER_NAME" su - opencode -c "screen -r $SESSION_NAME"
}

create_new_window() {
    log_info "Creating new window in session '$SESSION_NAME'..."
    docker exec -it "$CONTAINER_NAME" su - opencode -c "screen -r $SESSION_NAME -X screen"
    attach_to_session
}

show_ssh_info() {
    log_info "SSH Connection Information"
    echo ""
    
    if is_container_running; then
        # Try to get Tailscale IP
        local tailscale_ip
        tailscale_ip=$(docker exec opencode_tailscale tailscale ip -4 2>/dev/null || echo "unknown")
        
        echo "Container: $CONTAINER_NAME (running)"
        echo "Tailscale IP: $tailscale_ip"
        echo ""
        echo "SSH Command:"
        echo "  ssh opencode@$tailscale_ip"
        echo ""
        echo "Then attach to session:"
        echo "  screen -r $SESSION_NAME"
        echo ""
        echo "Note: Ensure SSH key is added to container"
        echo "  Run: ./add-ssh-key.sh <path-to-public-key>"
    else
        log_warn "Container is not running. Start it first with: ./scripts/opencode"
    fi
}

show_status() {
    local status
    status=$(get_container_status)
    
    echo "Container: $CONTAINER_NAME"
    echo "Status: $status"
    
    if [[ "$status" == "running" ]]; then
        echo ""
        echo "Services:"
        docker exec "$CONTAINER_NAME" su - opencode -c "screen -ls" 2>/dev/null || echo "  Screen: not available"
        docker exec "$CONTAINER_NAME" pgrep sshd >/dev/null && echo "  SSH: running" || echo "  SSH: not running"
        docker exec "$CONTAINER_NAME" su - opencode -c "docker ps" >/dev/null 2>&1 && echo "  Docker socket: accessible" || echo "  Docker socket: not accessible"
    fi
}

stop_container() {
    log_info "Stopping OpenCode container..."
    cd "$CONFIG_DIR"
    docker compose -f "$COMPOSE_FILE" down
    log_success "Container stopped"
}

# =============================================================================
# Main
# =============================================================================

main() {
    # Parse arguments
    case "${1:-}" in
        --help|-h)
            show_help
            exit 0
            ;;
        --ssh)
            check_docker
            show_ssh_info
            exit 0
            ;;
        --status)
            check_docker
            show_status
            exit 0
            ;;
        --stop)
            check_docker
            stop_container
            exit 0
            ;;
        --new-session)
            check_docker
            if ! is_container_running; then
                log_error "Container is not running. Start it first."
                exit 1
            fi
            create_new_window
            exit 0
            ;;
        "")
            # Default: attach or start
            ;;
        *)
            log_error "Unknown option: $1"
            echo ""
            show_help
            exit 1
            ;;
    esac
    
    # Preflight checks
    check_docker
    check_env
    
    # Check Remory
    check_remory
    
    # Check container status
    local status
    status=$(get_container_status)
    
    case "$status" in
        running)
            log_info "Container is already running"
            attach_to_session
            ;;
        stopped)
            log_info "Container exists but is stopped"
            start_container
            attach_to_session
            ;;
        not_created)
            log_info "Container not found, creating new one"
            start_container
            attach_to_session
            ;;
    esac
}

# Run main
main "$@"
