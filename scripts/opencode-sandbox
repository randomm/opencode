#!/usr/bin/env bash
# OpenCode Sandbox Launcher
# Starts containerized OpenCode environment with MCP server access
#
# Usage:
#   ./scripts/opencode-sandbox [workspace_path]
#   ./scripts/opencode-sandbox --update    # Force rebuild with latest OpenCode
#   ./scripts/opencode-sandbox --version   # Check OpenCode version in container
#
# Environment Variables:
#   WORKSPACE - Project directory to mount (default: ~/git)
#   PERPLEXITY_API_KEY - Required for Perplexity MCP server

set -euo pipefail

# =============================================================================
# Configuration
# =============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="$(dirname "$SCRIPT_DIR")"
COMPOSE_FILE="$CONFIG_DIR/docker-compose.opencode.yml"
REMORY_COMPOSE_FILE="${REMORY_COMPOSE_FILE:-$HOME/git/remory/docker-compose.mcp.yml}"

# Default workspace
DEFAULT_WORKSPACE="$HOME/git"
WORKSPACE="${1:-${WORKSPACE:-$DEFAULT_WORKSPACE}}"

# Parse flags
FORCE_BUILD=false
CHECK_VERSION=false

if [[ "${1:-}" == "--update" ]]; then
    FORCE_BUILD=true
    WORKSPACE="${2:-${WORKSPACE:-$DEFAULT_WORKSPACE}}"
elif [[ "${1:-}" == "--version" ]]; then
    CHECK_VERSION=true
fi

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# =============================================================================
# Helper Functions
# =============================================================================

log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

check_docker() {
    if ! command -v docker &> /dev/null; then
        log_error "Docker is not installed"
        exit 1
    fi

    if ! docker info &> /dev/null; then
        log_error "Docker daemon is not running"
        exit 1
    fi
}

check_env() {
    if [[ -z "${PERPLEXITY_API_KEY:-}" ]]; then
        log_warn "PERPLEXITY_API_KEY not set - Perplexity MCP server will not work"
        log_info "Set it in ~/.env or export it before running this script"
    fi
}

check_remory() {
    log_info "Checking Remory MCP server status..."

    if docker ps --filter "name=remory_mcp_server" --format "{{.Names}}" | grep -q remory_mcp_server; then
        log_success "Remory MCP server is running"
        return 0
    fi

    log_warn "Remory MCP server is not running"

    if [[ -f "$REMORY_COMPOSE_FILE" ]]; then
        log_info "Starting Remory services from $REMORY_COMPOSE_FILE"
        docker compose -f "$REMORY_COMPOSE_FILE" up -d

        # Wait for health check
        log_info "Waiting for Remory services to be healthy..."
        sleep 5

        if docker ps --filter "name=remory_mcp_server" --format "{{.Names}}" | grep -q remory_mcp_server; then
            log_success "Remory services started successfully"
        else
            log_error "Failed to start Remory services"
            exit 1
        fi
    else
        log_error "Remory compose file not found at $REMORY_COMPOSE_FILE"
        log_info "Please start Remory manually or update REMORY_COMPOSE_FILE path"
        exit 1
    fi
}

check_opencode_version() {
    log_info "Checking OpenCode version in container..."

    if docker ps --filter "name=opencode_sandbox" --format "{{.Names}}" | grep -q opencode_sandbox; then
        local container_version=$(docker exec opencode_sandbox opencode --version 2>/dev/null || echo "unknown")
        log_info "Container version: $container_version"
    else
        log_warn "Container is not running"
    fi

    if command -v opencode &> /dev/null; then
        local host_version=$(opencode --version 2>/dev/null || echo "unknown")
        log_info "Host version: $host_version"
    fi
}

start_sandbox() {
    log_info "Starting OpenCode sandbox..."

    # Export environment variables for docker-compose
    export USER_ID=$(id -u)
    export GROUP_ID=$(id -g)
    export WORKSPACE="$WORKSPACE"
    export PERPLEXITY_API_KEY="${PERPLEXITY_API_KEY:-}"
    export COMPOSE_BAKE=true

    # Build and start services
    cd "$CONFIG_DIR"

    if [[ "$FORCE_BUILD" == "true" ]]; then
        log_info "Force rebuilding with latest OpenCode CLI..."
        docker compose -f "$COMPOSE_FILE" build --no-cache opencode-sandbox
        docker compose -f "$COMPOSE_FILE" up -d
    else
        docker compose -f "$COMPOSE_FILE" up -d --build
    fi

    log_success "OpenCode sandbox is running"
    log_info "Workspace mounted: $WORKSPACE"

    # Show version after build
    sleep 2
    check_opencode_version
}

enter_sandbox() {
    log_info "Entering OpenCode sandbox..."
    echo ""
    log_info "===================================================================="
    log_info "  OpenCode Sandbox - Containerized Development Environment"
    log_info "===================================================================="
    log_info ""
    log_info "  Workspace:  /workspace"
    log_info "  Config:     /home/opencode/.config/opencode"
    log_info "  MCP Servers: Remory + Perplexity (via HTTP gateway)"
    log_info ""
    log_info "  Use 'opencode' CLI as normal"
    log_info "  Type 'exit' to leave the sandbox"
    log_info "===================================================================="
    echo ""

    docker exec -it opencode_sandbox zsh
}

cleanup() {
    log_info "Cleaning up..."
    # Optionally stop containers (comment out if you want them to keep running)
    # docker compose -f "$COMPOSE_FILE" down
}

# =============================================================================
# Main
# =============================================================================

main() {
    log_info "OpenCode Sandbox Launcher"
    echo ""

    # Handle --version flag
    if [[ "$CHECK_VERSION" == "true" ]]; then
        check_docker
        check_opencode_version
        exit 0
    fi

    # Preflight checks
    check_docker
    check_env

    # Check and start dependencies
    check_remory

    # Start sandbox
    start_sandbox

    # Enter sandbox
    enter_sandbox

    # Cleanup on exit
    cleanup

    log_success "Exited OpenCode sandbox"
}

# Trap errors
trap 'log_error "An error occurred. Exiting..."; exit 1' ERR

# Run main
main "$@"