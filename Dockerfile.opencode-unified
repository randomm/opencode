# OpenCode Unified Container
# Merges sandbox and SSH containers into single multi-access container
# Supports: Docker exec (Mac), SSH access (iPhone), persistent sessions (screen/tmux)

FROM node:20-slim

# Install all required packages in one layer
RUN apt-get update && apt-get install -y \
    # SSH server for remote access
    openssh-server \
    # Development tools
    git \
    bash \
    zsh \
    curl \
    unzip \
    vim \
    ca-certificates \
    python3 \
    python3-pip \
    # Docker CLI for MCP server access
    docker.io \
    # Session management
    screen \
    tmux \
    # Process management
    sudo \
    && rm -rf /var/lib/apt/lists/*

# Install GitHub CLI from official repository
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | \
    dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | \
    tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
    apt-get update && \
    apt-get install -y gh && \
    rm -rf /var/lib/apt/lists/*

# Create opencode user (UID 1001 to avoid conflicts)
RUN useradd -m -u 1001 -s /bin/zsh opencode

# Set up SSH server
RUN mkdir -p /run/sshd && \
    ssh-keygen -A && \
    mkdir -p /home/opencode/.ssh && \
    chown -R opencode:opencode /home/opencode/.ssh && \
    chmod 700 /home/opencode/.ssh

# Configure SSH daemon for security
RUN echo "PermitRootLogin no" >> /etc/ssh/sshd_config && \
    echo "PasswordAuthentication no" >> /etc/ssh/sshd_config && \
    echo "PubkeyAuthentication yes" >> /etc/ssh/sshd_config && \
    echo "AllowUsers opencode" >> /etc/ssh/sshd_config && \
    echo "X11Forwarding no" >> /etc/ssh/sshd_config && \
    echo "MaxAuthTries 3" >> /etc/ssh/sshd_config && \
    echo "ClientAliveInterval 300" >> /etc/ssh/sshd_config && \
    echo "ClientAliveCountMax 2" >> /etc/ssh/sshd_config && \
    echo "PermitEmptyPasswords no" >> /etc/ssh/sshd_config && \
    echo "ChallengeResponseAuthentication no" >> /etc/ssh/sshd_config

# Create placeholder docker group (actual GID will be set at runtime by entrypoint)
RUN groupadd docker || true

# Create required directories and files
RUN mkdir -p /home/opencode/.config/opencode \
             /home/opencode/.config/gh \
             /home/opencode/.local/share/opencode \
             /home/opencode/.local/state && \
    touch /home/opencode/.zshrc \
          /home/opencode/.bash_history \
          /home/opencode/.zsh_history && \
    chown -R opencode:opencode /home/opencode

# Install OpenCode CLI as opencode user
USER opencode
WORKDIR /home/opencode
RUN curl -fsSL https://opencode.ai/install | bash

# Copy screen configuration
COPY --chown=opencode:opencode .screenrc /home/opencode/.screenrc

# Set up shell environment
ENV SHELL=/bin/zsh
ENV TERM=xterm-256color
ENV PATH="/home/opencode/.opencode/bin:${PATH}"

# Copy OpenCode config
COPY --chown=opencode:opencode opencode.container.json /config/opencode.container.json

# Switch back to root for entrypoint (SSH daemon and screen session management)
USER root

# Copy entrypoint script
COPY entrypoint-unified.sh /entrypoint-unified.sh
RUN chmod +x /entrypoint-unified.sh

WORKDIR /workspace

ENTRYPOINT ["/entrypoint-unified.sh"]
