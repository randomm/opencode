# OpenCode Configuration Environment Variables
# Copy this file to .env and fill in your actual values

# Perplexity API Configuration
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Database Connections
# Format: postgres://username:password@host:port/database

# Fuzu Metabase Analytics Database (Read-only)
FUZU_METABASE_DB_URL=postgres://username:password@host:port/database

# Fuzu Production Database (Read-only)
FUZU_PRODUCTION_DB_URL=postgres://username:password@host:port/database

# Fuzu Staging Database (Read-only)
FUZU_STAGING_DB_URL=postgres://username:password@host:port/database

# Barona Production Database (Read-only)
BARONA_PRODUCTION_DB_URL=postgres://username:password@host:port/database

# MCP Memory Service Paths (optional - defaults shown)
MCP_MEMORY_CHROMA_PATH=/Users/janni/.claude_chroma_db
MCP_MEMORY_BACKUPS_PATH=/Users/janni/.claude_chroma_backups

# AWS Configuration (optional - for AWS RDS operations)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# GitHub Configuration (optional - for GitHub operations)
GITHUB_TOKEN=your_github_personal_access_token