  "mcp": {
    "perplexity-ask": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "perplexity-mcp"
      ],
      "enabled": true,
      "environment": {
        "PERPLEXITY_API_KEY": "{env:PERPLEXITY_API_KEY}",
        "PERPLEXITY_TIMEOUT_MS": "600000"
      }
    },
    "fuzu-production-db": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "mcp/postgres", "{env:FUZU_PRODUCTION_DB_RO}"],
      "enabled": true
    },
    "barona-production-db": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "mcp/postgres", "{env:BARONA_PRODUCTION_DB_RO}"],
      "enabled": true
    },
    "rollbar-error-investigation": {
      "type": "local",
      "command": ["npx", "@rollbar/mcp-server"],
