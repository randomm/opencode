{
  "$schema": "https://opencode.ai/config.json",
  "hooks": [
    {
      "name": "onSave",
      "matcher": "**/*.py",
      "run": [
        "ruff check --fix .",
        "mypy .",
        "black --quiet ."
      ]
    },
    {
      "name": "onSave",
      "matcher": "**/*.{js,ts,jsx,tsx}",
      "run": [
        "eslint . --fix",
        "tsc --noEmit",
        "prettier --write ."
      ]
    },
    {
      "name": "onSave",
      "matcher": "**/*.rs",
      "run": [
        "cargo clippy --all-targets",
        "cargo fmt --all"
      ]
    },
    {
      "name": "onSave",
      "matcher": "**/*.sh",
      "run": [
        "shellcheck -x $FILE"
      ]
    },
    {
      "name": "onSave",
      "matcher": "**/*.rb",
      "run": [
        "rubocop --autocorrect"
      ]
    },
    {
      "name": "onSave",
      "matcher": "**/*.go",
      "run": [
        "go fmt .",
        "golangci-lint run"
      ]
    }
  ],
  "instructions": [
    "instructions/memory-protocol-mandatory.md",
    "instructions/workflow-standards.md",
    "instructions/agent-responsibilities.md",
    "instructions/quality-standards.md",
    "instructions/tool-preferences.md",
    "instructions/shortcut-cli-awareness.md",
    "instructions/remory-cli-reference.md"
  ],
  "agent": {
    "project-manager": {
      "description": "Pure orchestrator that coordinates specialists but never executes code - read-only tools and delegation only",
      "mode": "primary",
      "prompt": "{file:prompts/project-manager.txt}",
      "permission": {
        "bash": {
          "remory *": "allow",
          "export PROJECT_ID=*": "allow",
          "cat *": "allow",
          "uuidgen*": "allow",
          "echo*": "allow",
          "tee*": "allow",
          "rg*": "allow",
          "jq*": "allow",
          "wc*": "allow",
          "gh issue view*": "allow",
          "gh issue list*": "allow",
          "gh issue create*": "allow",
          "gh issue edit*": "allow",
          "*": "deny"
        },
        "write": "deny",
        "edit": "deny"
      },
       "tools": {
         "bash": true,
         "glob": true,
         "grep": true,
         "list": true,
         "read": true,
         "webfetch": true,
         "websearch": true,
         "todowrite": true
       }
     },
