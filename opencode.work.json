              "."
            ],
            "environment": {}
          },
          {
            "command": [
              "mypy",
              "."
            ],
            "environment": {}
          },
          {
            "command": [
              "black",
              "--quiet",
              "."
            ],
            "environment": {}
          }
        ],
        "javascript_linter": [
          {
            "command": [
              "eslint",
              ".",
              "--fix"
            ],
            "environment": {}
          },
          {
            "command": [
              "prettier",
              "--write",
              "."
            ],
            "environment": {}
          }
        ],
        "rust_linter": [
          {
            "command": [
              "cargo",
              "clippy",
              "--all-targets"
            ],
            "environment": {}
          },
          {
            "command": [
              "cargo",
              "fmt",
              "--all"
            ],
            "environment": {}
          }
        ],
        "shell_linter": [
          {
            "command": [
              "shellcheck",
              "-x",
              "**/*.sh"
            ],
            "environment": {}
          }
        ],
        "ruby_linter": [
          {
            "command": [
              "rubocop",
              "--autocorrect"
            ],
            "environment": {}
          }
        ],
        "go_linter": [
          {
            "command": [
              "go",
              "fmt",
              "."
            ],
            "environment": {}
          },
          {
            "command": [
              "golangci-lint",
              "run"
            ],
            "environment": {}
          }
        ]
      }
    }
