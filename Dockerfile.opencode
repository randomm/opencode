# OpenCode Sandbox Container
# Debian-based container for running OpenCode CLI in isolation
# (OpenCode requires glibc, not available in Alpine's musl)
# with access to containerized MCP servers via HTTP gateway

FROM node:20-slim

# Install essential development tools
RUN apt-get update && apt-get install -y \
    git \
    openssh-client \
    bash \
    zsh \
    curl \
    unzip \
    vim \
    ca-certificates \
    python3 \
    python3-pip \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

# Rename node user to opencode and handle existing GIDs
ARG USER_ID=1000
ARG GROUP_ID=1000
RUN usermod -l opencode -d /home/opencode -m -u ${USER_ID} node && \
    if getent group ${GROUP_ID} | grep -v "^node:" >/dev/null 2>&1; then \
        EXISTING_GROUP=$(getent group ${GROUP_ID} | cut -d: -f1) && \
        usermod -g ${EXISTING_GROUP} opencode && \
        groupdel node; \
    else \
        groupmod -n opencode -g ${GROUP_ID} node; \
    fi

# Create required directories
RUN mkdir -p /home/opencode/.config/opencode \
             /home/opencode/.local/share/opencode \
             /home/opencode/.local/state && \
    touch /home/opencode/.zshrc && \
    chown -R ${USER_ID}:${GROUP_ID} /home/opencode

# Install OpenCode CLI as opencode user
USER opencode
WORKDIR /home/opencode
RUN curl -fsSL https://opencode.ai/install | bash

# Set up working directory for actual work
WORKDIR /workspace

# Set up shell environment
ENV SHELL=/bin/zsh
ENV TERM=xterm-256color
ENV PATH="/home/opencode/.opencode/bin:${PATH}"

# Default command: interactive shell
CMD ["/bin/zsh"]