# OpenCode Container - Screen configuration
# Minimal configuration for SSH sessions with proper terminal compatibility

# Terminal type for screen sessions
term screen-256color

# UTF-8 support
defutf8 on
encoding UTF-8 UTF-8

# Enable background color erase (correct colors in vim, etc.)
defbce on

# Scrollback buffer
defscrollback 10000

# Don't show startup message
startup_message off

# Status line (helpful for remote sessions)
hardstatus alwayslastline "%{= kw}%-w%{= BW}%n %t%{-}%+w %= %c"

# Don't block on output (better for SSH)
nonblock on

# Start login shell (sources .zshrc properly)
defshell -zsh

# REMOVED: bindkey -k kb stuff ^H
# Let screen pass through terminal backspace codes naturally
# Modern terminals send ^? (DEL), which zsh now handles via .zshrc
