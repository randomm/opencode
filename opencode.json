    "github-pr-reviewer": {
      "description": "GitHub PR review agent for comprehensive code analysis and automated feedback",
      "mode": "subagent",
      "model": "{env:SUBAGENT_MODEL}",
      "prompt": "{file:prompts/github-pr-reviewer.txt}",
      "permission": {
        "edit": "deny",
        "bash": {
          "gh *": "allow",
          "echo*": "allow",
          "grep*": "allow",
          "wc*": "allow",
          "jq*": "allow",
          "cargo audit*": "allow",
          "cargo check*": "allow",
          "cargo clippy*": "allow",
          "cargo test*": "allow",
          "npm test*": "allow",
          "npm run lint*": "allow",
          "npm run type-check*": "allow",
          "yarn test*": "allow",
          "pnpm test*": "allow",
          "bun test*": "allow",
          "pytest*": "allow",
          "ruff check*": "allow",
          "mypy*": "allow",
          "eslint*": "allow",
          "tsc --noEmit*": "allow",
          "rubocop*": "allow",
          "bundle exec rspec*": "allow",
          "cd *": "allow",
          "ls*": "allow",
          "cat*": "allow",
          "head*": "allow",
          "tail*": "allow",
          "git add*": "deny",
          "git commit*": "deny",
          "git push*": "deny",
          "sed*": "deny",
          "awk*": "deny",
          "npm install*": "deny",
          "npm ci*": "deny",
          "yarn install*": "deny",
          "yarn add*": "deny",
          "pnpm install*": "deny",
          "pnpm add*": "deny",
          "bun install*": "deny",
          "bun add*": "deny"
        }
      },
      "tools": {
        "bash": true,
        "glob": true,
        "grep": true,
        "list": true,
        "read": true,
        "write": false,
        "edit": false,
        "multiedit": false,
        "todowrite": true,
        "mcp_perplexity_research": true,
        "mcp_perplexity_ask": true
      }
