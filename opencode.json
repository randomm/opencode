  "agent": {
    "project-manager": {
      "description": "Pure orchestrator that coordinates specialists but never executes code - read-only tools and delegation only",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-5-20250929",
      "prompt": "{file:prompts/project-manager.txt}",
      "permission": {
        "bash": "deny",
        "write": "deny",
        "edit": "deny"
      },
      "tools": {
        "glob": true,
        "grep": true,
        "list": true,
        "read": true,
        "webfetch": true,
        "websearch": true,
        "todowrite": true
      }
    },
    "python-best-practices-architect": {
      "description": "Minimalist Python architect enforcing TDD, 80%+ coverage, and quality gates",
