    "memory": {
      "type": "local",
      "command": ["docker", "exec", "-i", "remory_mcp_server", "python", "-m", "remory.mcp"],
      "enabled": true
    },
    "perplexity-ask": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "-e", "PERPLEXITY_API_KEY", "mcp/perplexity-ask"],
      "enabled": true,
      "environment": {
        "PERPLEXITY_API_KEY": "{env:PERPLEXITY_API_KEY}"
      }
    }
  },
